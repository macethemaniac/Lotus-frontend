{
  "name": "lotus-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "cf:dev": "wrangler dev",
    "cf:deploy:main": "npm run build && wrangler deploy --env production",
    "cf:deploy:production": "npm run build && wrangler deploy --env production"
  },
  "overrides": {
    "@walletconnect/jsonrpc-ws-connection": {
      "ws": "7.5.11"
    },
    "isows": {
      "ws": "7.5.11"
    },
    "@fortawesome/react-fontawesome": "3.1.1"
  },
  "dependencies": {
    "@turnkey/react-wallet-kit": "^2.0.0",
    "@types/qrcode": "^1.5.6",
    "ethers": "^6.16.0",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.108.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260701.1": true,
    "workerd@1.20260706.1": true
  }
